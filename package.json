{
  "name": "cloudconvert-job-builder",
  "version": "0.1.0",
  "description": "CloudConvert Job Builder with compile-time dependency checks.",
  "homepage": "https://github.com/dbrxnds/cloudconvert-job-builder#readme",
  "bugs": {
    "url": "https://github.com/dbrxnds/cloudconvert-job-builder/issues"
  },
  "license": "MIT",
  "author": "David <me@dbrands.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbrxnds/cloudconvert-job-builder.git"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "release": "bumpp -x \"pnpm publish\"",
    "prepublishOnly": "vp pack",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "cloudconvert": "^3.0.0",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.14",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "cloudconvert": "^3.0.0",
    "typescript": "^5.4.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.23.0"
}
